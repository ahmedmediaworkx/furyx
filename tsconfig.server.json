{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/server-nest/**/*.ts",
    "src/models/**/*.ts",
    "src/lib/db.ts",
    "src/lib/socket-state.js"
  ]
}